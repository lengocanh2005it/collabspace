# =============================================================================
# User Service — environment template
# Copy to .env, điền non-secret config, sau đó chạy sync script để lấy secrets.
#
# Docker Compose: postgres, rabbitmq, auth-service hostnames
# Local pnpm:     localhost:5432, localhost:5672, AUTH_SERVICE_GRPC_URL=127.0.0.1:50051
#
# SECRETS — không điền tay, lấy từ Vault:
#   .\infrastructure\vault\scripts\sync-env-from-vault.ps1
# =============================================================================

NODE_ENV=development
PORT=3000

# -- PostgreSQL ----------------------------------------------------------------
# Password trong URL là VAULT-MANAGED
DATABASE_URL=postgresql://postgres:VAULT_SYNC@postgres:5432/collabspace_user?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# -- RabbitMQ ------------------------------------------------------------------
# Credentials trong URL là VAULT-MANAGED
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://user:VAULT_SYNC@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=user-service
RABBITMQ_DLX_EXCHANGE=collabspace_dlx
RABBITMQ_DLX_ROUTING_KEY=user-service.dlq
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false

# -- gRPC server ---------------------------------------------------------------
GRPC_ENABLED=true
GRPC_URL=0.0.0.0:50052

# -- Auth gRPC -----------------------------------------------------------------
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000

# -- Internal API --------------------------------------------------------------
# Phải khớp với task-service + notification-service INTERNAL_SERVICE_TOKEN
INTERNAL_SERVICE_TOKEN=              # VAULT-MANAGED

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)

# -- Azure Blob (avatar upload) -----------------------------------------------
# Optional — không set = mock URL (ui-avatars.com), không persist blob
# AZURE_STORAGE_CONNECTION_STRING=   # VAULT-MANAGED (prod)
