# User Service Environment Variables
NODE_ENV=development
PORT=3000

# PostgreSQL (database: collabspace_user)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/collabspace_user?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# RabbitMQ
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=user-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false

# JWT (for validating tokens issued by auth-service)
JWT_SECRET=your-secret-key-change-in-production
