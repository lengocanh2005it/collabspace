# Auth Service Environment Variables
NODE_ENV=development
PORT=3000

# PostgreSQL (database: collabspace_auth)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/collabspace_auth?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_AUTO_LOAD_ENTITIES=true

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h
JWT_ISSUER=
JWT_AUDIENCE=

# Email Verification
EMAIL_VERIFICATION_OTP_LENGTH=6
EMAIL_VERIFICATION_OTP_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_RESEND_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=3600
PASSWORD_RESET_TOKEN_BYTE_LENGTH=32
PASSWORD_RESET_TTL_SECONDS=1800
USER_SERVICE_GRPC_URL=user-service:50052
USER_SERVICE_GRPC_TIMEOUT_MS=3000

# Refresh Token Rotation
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_BYTE_LENGTH=48

# RabbitMQ (for publishing auth events)
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=auth-service
RABBITMQ_USER_SERVICE_QUEUE=user-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false
RABBITMQ_PUBLISH_TIMEOUT_MS=3000

# Email / SMTP
MAIL_URL=
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_IGNORE_TLS=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@collabspace.local
MAIL_DELIVERY_TIMEOUT_MS=5000

# Graphile Worker
GRAPHILE_WORKER_ENABLED=false
GRAPHILE_WORKER_CONCURRENCY=5
GRAPHILE_WORKER_POLL_INTERVAL=2000
GRAPHILE_WORKER_SCHEMA=graphile_worker

# gRPC
GRPC_ENABLED=false
GRPC_URL=0.0.0.0:50051

# Redis
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_KEY_PREFIX=auth:
