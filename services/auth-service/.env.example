# =============================================================================
# Auth Service — environment template
# Copy to .env and adjust.
#
# Docker Compose: hostnames postgres, redis, rabbitmq, user-service, ...
# Local pnpm:     localhost + mapped ports (5432, 6379, 5672, 50052, ...)
# =============================================================================

NODE_ENV=development
PORT=3000

# PostgreSQL (database: collabspace_auth)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/collabspace_auth?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_AUTO_LOAD_ENTITIES=true

# JWT — share JWT_SECRET with notification-service (legacy config path)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h
JWT_ISSUER=
JWT_AUDIENCE=

# Email verification / password reset
EMAIL_VERIFICATION_OTP_LENGTH=6
EMAIL_VERIFICATION_OTP_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_RESEND_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=3600
PASSWORD_RESET_TOKEN_BYTE_LENGTH=32
PASSWORD_RESET_TTL_SECONDS=1800

# Refresh tokens
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_BYTE_LENGTH=48

# User service gRPC (create pending profile on register)
USER_SERVICE_GRPC_URL=user-service:50052
USER_SERVICE_GRPC_TIMEOUT_MS=3000

# RabbitMQ (publish integration events)
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=auth-service
RABBITMQ_USER_SERVICE_QUEUE=user-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false
RABBITMQ_PUBLISH_TIMEOUT_MS=3000

# SMTP (optional — outbox can queue; use Mailtrap for real sends)
MAIL_URL=
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_IGNORE_TLS=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@collabspace.local
MAIL_DELIVERY_TIMEOUT_MS=5000

# Graphile Worker (background jobs; uses same Postgres)
GRAPHILE_WORKER_ENABLED=false
GRAPHILE_WORKER_CONCURRENCY=5
GRAPHILE_WORKER_POLL_INTERVAL=2000
GRAPHILE_WORKER_SCHEMA=graphile_worker

# Transactional outbox (email, etc.)
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_CLAIM_THRESHOLD_MS=60000
OUTBOX_DEGRADED_PENDING_THRESHOLD=50
OUTBOX_DEGRADED_FAILED_THRESHOLD=1

# gRPC server (VerifyAccessToken for gateway + peer services)
GRPC_ENABLED=true
GRPC_URL=0.0.0.0:50051

# Redis (sessions / rate limits)
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=collabspace123
REDIS_KEY_PREFIX=auth:

TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# Metrics scrape lockdown (optional — leave empty for open /metrics in local dev)
METRICS_AUTH_TOKEN=
