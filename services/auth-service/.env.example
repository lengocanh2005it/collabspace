# =============================================================================
# Auth Service — environment template
# Copy to .env, điền non-secret config, sau đó chạy sync script để lấy secrets.
#
# Docker Compose: hostnames postgres, redis, rabbitmq, user-service, ...
# Local pnpm:     localhost + mapped ports (5432, 6379, 5672, 50052, ...)
#
# SECRETS — không điền tay, lấy từ Vault:
#   .\infrastructure\vault\scripts\sync-env-from-vault.ps1
# =============================================================================

NODE_ENV=development
PORT=3000

# -- PostgreSQL ----------------------------------------------------------------
# Password trong URL là VAULT-MANAGED — sync script sẽ điền đúng giá trị
DATABASE_URL=postgresql://postgres:VAULT_SYNC@postgres:5432/collabspace_auth?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_AUTO_LOAD_ENTITIES=true

# -- JWT -----------------------------------------------------------------------
JWT_SECRET=                          # VAULT-MANAGED
JWT_EXPIRY=24h
JWT_ISSUER=
JWT_AUDIENCE=

# -- Verify lite cache (downstream AuthGuard hot path) ---------------------------
AUTH_VERIFY_LITE_CACHE_ENABLED=true
AUTH_VERIFY_LITE_CACHE_MAX_TTL_SECONDS=300

# -- Email verification / password reset ---------------------------------------
EMAIL_VERIFICATION_OTP_LENGTH=6
EMAIL_VERIFICATION_OTP_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_RESEND_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=3600
PASSWORD_RESET_TOKEN_BYTE_LENGTH=32
PASSWORD_RESET_TTL_SECONDS=1800

# -- Refresh tokens ------------------------------------------------------------
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_BYTE_LENGTH=48

# -- User service gRPC ---------------------------------------------------------
USER_SERVICE_GRPC_URL=user-service:50052
USER_SERVICE_GRPC_TIMEOUT_MS=3000

# -- RabbitMQ ------------------------------------------------------------------
# Credentials trong URL là VAULT-MANAGED
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://user:VAULT_SYNC@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=auth-service
RABBITMQ_DLX_EXCHANGE=collabspace_dlx
RABBITMQ_DLX_ROUTING_KEY=auth-service.dlq
RABBITMQ_USER_SERVICE_QUEUE=user-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false
RABBITMQ_PUBLISH_TIMEOUT_MS=3000

# -- Brevo transactional email (OTP xác thực & reset password) -----------------
# API key: Brevo dashboard → SMTP & API → API keys (xkeysib-...)
# Sender email phải được verify trong Brevo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=CollabSpace Platform
EMAIL_DELIVERY_TIMEOUT_MS=15000

# -- Outbox --------------------------------------------------------------------
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_CLAIM_THRESHOLD_MS=60000
OUTBOX_DEGRADED_PENDING_THRESHOLD=50
OUTBOX_DEGRADED_FAILED_THRESHOLD=1

# -- gRPC server ---------------------------------------------------------------
GRPC_ENABLED=true
GRPC_URL=0.0.0.0:50051

# -- Redis ---------------------------------------------------------------------
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=                      # VAULT-MANAGED
REDIS_KEY_PREFIX=auth:

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)
