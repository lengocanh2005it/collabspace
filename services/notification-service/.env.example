# =============================================================================
# Notification Service — environment template
# Copy to .env (cp .env.example .env). Đừng commit .env.
#
# Bootstrap secrets — chọn một:
#
# A) Vault (khuyến nghị — field VAULT_SYNC / để trống được sync tự động):
#    cd infrastructure/docker && docker compose -f docker-compose.vault.yml up -d
#    cd ../.. && .\infrastructure\vault\scripts\seed-dev-secrets.ps1
#    .\infrastructure\vault\scripts\sync-env-from-vault.ps1
#
# B) Điền tay — khớp infrastructure/docker/.env.example + vault/.env.example
#
# Docker Compose: mongo (rs0), redis, kafka, user/auth services
# Kafka migration: docs/kafka-debezium-migration-roadmap.md
# =============================================================================

NODE_ENV=development
PORT=3000

# -- Auth gRPC -----------------------------------------------------------------
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
ALLOW_DEV_IDENTITY_HEADERS=true

# -- MongoDB -------------------------------------------------------------------
MONGO_URI=mongodb://user:VAULT_SYNC@mongo:27017/collabspace_notification?authSource=admin&replicaSet=rs0

# -- Redis ---------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                      # VAULT-MANAGED
REDIS_DB=0

# -- Kafka consumers (workspace + user + task events) --------------------------
# Docker: KAFKA_BROKERS=kafka:9092 | host pnpm: localhost:29092
# Consumer groups: ${KAFKA_GROUP_ID}-workspace-events, -user-events, -task-events
KAFKA_CONSUMERS_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=notification-service
KAFKA_GROUP_ID=notification-service
# Topic defaults (Debezium Outbox Event Router — override nếu connector đổi tên):
# KAFKA_TOPIC_WORKSPACE_INVITED=collabspace.workspace.workspace_invited
# KAFKA_TOPIC_WORKSPACE_DELETED=collabspace.workspace.workspace_deleted
# KAFKA_TOPIC_USER_PROFILE_UPDATED=collabspace.user.profile_updated
# KAFKA_TOPIC_USER_REGISTERED=collabspace.user.registered
# KAFKA_TOPIC_TASK_ASSIGNED=collabspace.task.task_assigned
# KAFKA_TOPIC_COMMENT_CREATED=collabspace.task.comment_created
# KAFKA_TOPIC_COMMENT_MENTIONED=collabspace.task.comment_mentioned
# Phase 7 — DLQ + consumer retry (see docs/runbooks/KafkaDlqNotEmpty.md)
KAFKA_DLQ_TOPIC=collabspace.dlq.events
KAFKA_CONSUMER_MAX_RETRIES=3
KAFKA_CONSUMER_RETRY_DELAY_MS=1000

# -- JWT -----------------------------------------------------------------------
JWT_SECRET=                          # VAULT-MANAGED

# -- User replica fallback -----------------------------------------------------
USER_SERVICE_URL=http://user-service:3000
USER_SERVICE_TIMEOUT_MS=3000
USER_REPLICA_FALLBACK_ENABLED=true

# -- Service-to-service HTTP (Service JWT) ------------------------------------
SERVICE_JWT_SECRET=                  # VAULT-MANAGED

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)
