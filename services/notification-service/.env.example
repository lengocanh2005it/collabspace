# =============================================================================
# Notification Service — environment template
# Docker: mongo, rabbitmq, redis
# =============================================================================

NODE_ENV=development
PORT=3000

# MongoDB (database: collabspace_notification)
MONGO_URI=mongodb://admin:password@mongo:27017/collabspace_notification?authSource=admin

# Redis (reserved for future realtime; optional for current MVP)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=collabspace123
REDIS_DB=0

# RabbitMQ consumer (workspace_invited, task_assigned, comment_created, comment_mentioned)
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=notification-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false

# JWT (optional; HTTP API uses X-User-Id from gateway)
JWT_SECRET=your-secret-key-change-in-production

TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# Metrics scrape lockdown (optional)
METRICS_AUTH_TOKEN=
