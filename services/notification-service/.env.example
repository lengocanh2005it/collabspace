# =============================================================================
# Notification Service — environment template
# Copy to .env (cp .env.example .env). Đừng commit .env.
#
# Bootstrap secrets — chọn một:
#
# A) Vault (khuyến nghị — field VAULT_SYNC / để trống được sync tự động):
#    cd infrastructure/docker && docker compose -f docker-compose.vault.yml up -d
#    cd ../.. && .\infrastructure\vault\scripts\seed-dev-secrets.ps1
#    .\infrastructure\vault\scripts\sync-env-from-vault.ps1
#
# B) Điền tay — khớp infrastructure/docker/.env.example + vault/.env.example
#
# Docker Compose: mongo, redis, kafka, user-service, auth-service
# Kafka migration: docs/kafka-debezium-migration-roadmap.md
# =============================================================================

NODE_ENV=development
PORT=3000

# -- Auth gRPC -----------------------------------------------------------------
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
ALLOW_DEV_IDENTITY_HEADERS=true

# -- MongoDB -------------------------------------------------------------------
MONGO_URI=mongodb://user:VAULT_SYNC@mongo:27017/collabspace_notification?authSource=admin

# -- Redis ---------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                      # VAULT-MANAGED
REDIS_DB=0

# -- RabbitMQ ------------------------------------------------------------------
# Local Kafka stack: RABBITMQ_ENABLED=false (URL vẫn cần — ConfigurationService validate)
# Prod dual-run: RABBITMQ_ENABLED=true
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://user:VAULT_SYNC@rabbitmq:5672/collabspace

# -- Kafka consumers (workspace + user replica sync) ---------------------------
# Docker: KAFKA_BROKERS=kafka:9092 | host pnpm: localhost:29092
# Topic defaults: collabspace.workspace.*, collabspace.user.* (xem service-contracts.md)
KAFKA_CONSUMERS_ENABLED=true
KAFKA_BROKERS=kafka:9092

# -- JWT -----------------------------------------------------------------------
JWT_SECRET=                          # VAULT-MANAGED

# -- User replica fallback -----------------------------------------------------
USER_SERVICE_URL=http://user-service:3000
USER_SERVICE_TIMEOUT_MS=3000
USER_REPLICA_FALLBACK_ENABLED=true

# -- Service-to-service HTTP (Service JWT) ------------------------------------
SERVICE_JWT_SECRET=                  # VAULT-MANAGED

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)
