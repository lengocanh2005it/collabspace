# =============================================================================
# Notification Service — environment template
# Docker: mongo, rabbitmq, redis, user-service, auth-service
# =============================================================================

NODE_ENV=development
PORT=3000

# Auth gRPC (JWT verification on protected routes)
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
# Local curl without JWT (direct port only): set true in dev; never in production
ALLOW_DEV_IDENTITY_HEADERS=false

# MongoDB (database: collabspace_notification)
MONGO_URI=mongodb://admin:password@mongo:27017/collabspace_notification?authSource=admin

# Redis (reserved for future realtime; optional for current MVP)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=collabspace123
REDIS_DB=0

# RabbitMQ consumer (workspace_invited, task_assigned, comment_created, comment_mentioned)
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=notification-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false

# Legacy — align with auth-service JWT_SECRET if referenced by config
JWT_SECRET=your-secret-key-change-in-production

# User replica sync + fallback hydration (internal API + token)
USER_SERVICE_URL=http://user-service:3000
USER_SERVICE_TIMEOUT_MS=3000
USER_REPLICA_FALLBACK_ENABLED=true

# Shared with user-service + workspace-service + task-service (required in production)
INTERNAL_SERVICE_TOKEN=

TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

METRICS_AUTH_TOKEN=
