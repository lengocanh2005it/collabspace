# Notification Service Environment Variables
NODE_ENV=development
PORT=3000

# Redis (notification storage + pub/sub)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=collabspace123
REDIS_DB=0

# RabbitMQ (consumer: TASK_ASSIGNED, WORKSPACE_INVITED, COMMENT_CREATED)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_ENABLED=true
RABBITMQ_QUEUE=notification-service

# JWT (for validating tokens on WebSocket connections)
JWT_SECRET=your-secret-key-change-in-production

# Observability (optional)
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger