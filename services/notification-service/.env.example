# =============================================================================
# Notification Service — environment template
# Copy to .env, điền non-secret config, sau đó chạy sync script để lấy secrets.
#
# Docker Compose: mongo, rabbitmq, redis, kafka (optional), user-service, auth-service
# Kafka migration: docs/kafka-debezium-migration-roadmap.md
#
# SECRETS — không điền tay, lấy từ Vault:
#   .\infrastructure\vault\scripts\sync-env-from-vault.ps1
# =============================================================================

NODE_ENV=development
PORT=3000

# -- Auth gRPC -----------------------------------------------------------------
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
# Cho phép X-User-Id header ở local dev — KHÔNG bật trên production
ALLOW_DEV_IDENTITY_HEADERS=true

# -- MongoDB -------------------------------------------------------------------
# Credentials trong URI là VAULT-MANAGED
MONGO_URI=mongodb://user:VAULT_SYNC@mongo:27017/collabspace_notification?authSource=admin

# -- Redis ---------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                      # VAULT-MANAGED
REDIS_DB=0

# -- RabbitMQ ------------------------------------------------------------------
# Credentials trong URL là VAULT-MANAGED
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://user:VAULT_SYNC@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=notification-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false
RABBITMQ_MAX_RETRIES=5
RABBITMQ_DLX_EXCHANGE=collabspace_dlx
RABBITMQ_DLX_ROUTING_KEY=notification-service.dlq
COMMAND_TIMEOUT_MS=10000

# -- Kafka (Phase 2+ — dual-run với RabbitMQ; cần docker-compose.kafka.yml) ----
# Docker Compose (notification-service container): KAFKA_BROKERS=kafka:9092
# pnpm start:dev trên host: KAFKA_BROKERS=localhost:29092
# Bật consumer sau Phase 1 (Debezium connector đã register):
KAFKA_CONSUMERS_ENABLED=false
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=notification-service
KAFKA_GROUP_ID=notification-service
KAFKA_TOPIC_WORKSPACE_INVITED=collabspace.workspace.workspace_invited
KAFKA_TOPIC_WORKSPACE_DELETED=collabspace.workspace.workspace_deleted
KAFKA_TOPIC_USER_PROFILE_UPDATED=collabspace.user.profile_updated

# -- JWT -----------------------------------------------------------------------
JWT_SECRET=                          # VAULT-MANAGED

# -- User replica fallback -----------------------------------------------------
USER_SERVICE_URL=http://user-service:3000
USER_SERVICE_TIMEOUT_MS=3000
USER_REPLICA_FALLBACK_ENABLED=true

# -- Service-to-service HTTP (Service JWT) ------------------------------------
# Khớp trên user / workspace / task / notification — xem infrastructure/docker/.env.example
# Local: dùng giá trị mặc định bên dưới; prod: sync từ Vault
SERVICE_JWT_SECRET=collabspace-dev-service-jwt-secret-change-me

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)
