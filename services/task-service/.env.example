# =============================================================================
# Task Service — environment template
# Copy to .env, điền non-secret config, sau đó chạy sync script để lấy secrets.
#
# Docker Compose: mongo, kafka, workspace-service, user-service, auth-service
# Kafka migration: docs/kafka-debezium-migration-roadmap.md
#
# SECRETS — không điền tay, lấy từ Vault:
#   .\infrastructure\vault\scripts\sync-env-from-vault.ps1
# =============================================================================

NODE_ENV=development
PORT=3000

# -- Auth gRPC -----------------------------------------------------------------
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
ALLOW_DEV_IDENTITY_HEADERS=true

# -- MongoDB -------------------------------------------------------------------
MONGO_URI=mongodb://user:VAULT_SYNC@mongo:27017/collabspace_task?authSource=admin

# -- RabbitMQ ------------------------------------------------------------------
# Local Kafka stack: RABBITMQ_ENABLED=false (URL vẫn cần — ConfigurationService validate)
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://user:VAULT_SYNC@rabbitmq:5672/collabspace

# -- Kafka consumers (workspace_deleted cleanup + user replica sync) -------------
# Docker: KAFKA_BROKERS=kafka:9092 | host pnpm: localhost:29092
KAFKA_CONSUMERS_ENABLED=true
KAFKA_BROKERS=kafka:9092

# -- Workspace service (internal membership check) ----------------------------
WORKSPACE_CLIENT_MODE=http
WORKSPACE_SERVICE_URL=http://workspace-service:8080
WORKSPACE_SERVICE_TIMEOUT_MS=3000
WORKSPACE_MEMBERSHIP_CACHE_ENABLED=true
WORKSPACE_MEMBERSHIP_CACHE_TTL_SECONDS=60
WORKSPACE_MEMBERSHIP_CACHE_MAX_ENTRIES=2000

# -- User replica fallback -----------------------------------------------------
USER_SERVICE_URL=http://user-service:3000
USER_SERVICE_TIMEOUT_MS=3000
USER_REPLICA_FALLBACK_ENABLED=true

# -- Service-to-service HTTP (Service JWT) ------------------------------------
SERVICE_JWT_SECRET=collabspace-dev-service-jwt-secret-change-me

# -- Task outbox (RMQ publish — Phase 5M sẽ migrate sang Kafka) ----------------
TASK_OUTBOX_ENABLED=true
TASK_OUTBOX_POLL_INTERVAL_MS=2000
TASK_OUTBOX_MAX_ATTEMPTS=8

# -- Azure Blob (attachments) --------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=task-attachments
AZURE_STORAGE_MAX_FILE_SIZE=5242880

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)
