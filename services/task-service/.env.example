# Task Service Environment Variables
NODE_ENV=development
PORT=3000

# MongoDB (database: collabspace_task)
MONGO_URI=mongodb://mongo:27017/collabspace_task

# JWT (for validating tokens issued by auth-service)
JWT_SECRET=your-secret-key-change-in-production

# RabbitMQ (for publishing task events: TASK_ASSIGNED, COMMENT_CREATED)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace

# Azure Blob Storage (for file attachments storage)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=collabspace;AccountKey=your_account_key_here;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=task-attachments
AZURE_STORAGE_MAX_FILE_SIZE=5242880