# =============================================================================
# Task Service — environment template
# Docker: mongo, rabbitmq, workspace-service
# Local:  mongodb://admin:password@localhost:27017/...?authSource=admin
# =============================================================================

NODE_ENV=development
PORT=3000

# MongoDB (database: collabspace_task)
MONGO_URI=mongodb://admin:password@mongo:27017/collabspace_task?authSource=admin

# JWT (must match auth-service JWT_SECRET if validating tokens locally)
JWT_SECRET=your-secret-key-change-in-production

# RabbitMQ (task_assigned, comment_created, comment_mentioned)
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace
RABBITMQ_QUEUE=task-service
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_NO_ACK=false

# Workspace membership checks: mock | http
WORKSPACE_CLIENT_MODE=http
WORKSPACE_SERVICE_URL=http://workspace-service:8080
WORKSPACE_SERVICE_TIMEOUT_MS=3000

# User replica fallback (hydrate from user-service when local copy missing/stale)
USER_SERVICE_URL=http://user-service:3000
USER_SERVICE_TIMEOUT_MS=3000
USER_REPLICA_FALLBACK_ENABLED=true
INTERNAL_SERVICE_TOKEN=

# Task outbox processor
TASK_OUTBOX_ENABLED=true
TASK_OUTBOX_POLL_INTERVAL_MS=2000
TASK_OUTBOX_MAX_ATTEMPTS=8

# Azure Blob attachments (leave placeholder for mock upload mode)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key_here;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=task-attachments
AZURE_STORAGE_MAX_FILE_SIZE=5242880

TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# Metrics scrape lockdown (optional)
METRICS_AUTH_TOKEN=
