# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb://admin:password@localhost:27017/collabspace_analytics?authSource=admin&replicaSet=rs0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=analytics-service
KAFKA_GROUP_ID=analytics-service
KAFKA_CONSUMERS_ENABLED=false
KAFKA_DLQ_TOPIC=collabspace.dlq.events
KAFKA_CONSUMER_MAX_RETRIES=3
KAFKA_CONSUMER_RETRY_DELAY_MS=1000

# Topics
KAFKA_TOPIC_AUTH_EVENTS=collabspace.auth.events
KAFKA_TOPIC_WORKSPACE_EVENTS=collabspace.workspace.events
KAFKA_TOPIC_TASK_EVENTS=collabspace.task.events

# Auth
JWT_SECRET=change-me-dev
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000

# Metrics
METRICS_AUTH_TOKEN=

# Swagger
SWAGGER_ENABLED=true
