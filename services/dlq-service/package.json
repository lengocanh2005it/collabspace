{
  "name": "dlq-service",
  "version": "1.0.0",
  "description": "CollabSpace Dead Letter Queue ops service — ingest, inspect, replay, discard",
  "main": "dist/main.js",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build": "node -e \"for (const f of ['tsconfig.tsbuildinfo','tsconfig.build.tsbuildinfo']) { try { require('fs').unlinkSync(f); } catch {} }\" && nest build",
    "format": "pnpm -w exec biome format --write src test",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix --format json --max-warnings 0",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:cov": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "test:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-e2e.json",
    "seed": "node -r ts-node/register -r tsconfig-paths/register src/seed.ts",
    "seed:prod": "node dist/seed.js"
  },
  "keywords": [
    "dlq",
    "dead-letter-queue",
    "kafka",
    "nestjs",
    "ops"
  ],
  "author": "CollabSpace Team",
  "license": "MIT",
  "dependencies": {
    "@collabspace/nest-auth": "workspace:*",
    "@collabspace/shared": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^9.6.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@collabspace/eslint-config": "workspace:*",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "moduleNameMapper": {
      "^uuid$": "uuid"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
