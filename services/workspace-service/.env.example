# Workspace Service Environment Variables (Java/Spring Boot)
SERVER_PORT=8080

# PostgreSQL (database: collabspace_workspace)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/collabspace_workspace
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Flyway
SPRING_FLYWAY_ENABLED=true

# JWT (for validating tokens issued by auth-service)
JWT_SECRET=your-secret-key-change-in-production

# RabbitMQ (for publishing workspace events)
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
SPRING_RABBITMQ_VIRTUAL_HOST=collabspace