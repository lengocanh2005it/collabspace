NODE_ENV=development
PORT=8080

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/collabspace_workspace
DATABASE_SCHEMA=public
DATABASE_LOGGING=true
DATABASE_SYNCHRONIZE=true

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace

# Tracing
JAEGER_ENDPOINT=http://jaeger:14268/api/traces