# =============================================================================
# Workspace Service — environment template
# Docker: postgres, rabbitmq, auth-service
# Local pnpm: AUTH_SERVICE_GRPC_URL=127.0.0.1:50051
# =============================================================================

NODE_ENV=development
PORT=8080

# Auth gRPC (JWT verification on protected routes)
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
# Local curl without JWT (direct port only): set true in dev; never in production
ALLOW_DEV_IDENTITY_HEADERS=true

# Internal API: GET /api/v1/workspaces/internal/:id/membership
# Must match task-service INTERNAL_SERVICE_TOKEN
INTERNAL_SERVICE_TOKEN=collabspace-dev-internal-token-change-me

# PostgreSQL (database: collabspace_workspace)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/collabspace_workspace?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_LOGGING=true
DATABASE_SYNCHRONIZE=true

# RabbitMQ (workspace_invited events)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/collabspace

# Transactional outbox
WORKSPACE_OUTBOX_ENABLED=true
WORKSPACE_OUTBOX_POLL_INTERVAL_MS=2000
WORKSPACE_OUTBOX_BATCH_SIZE=25
WORKSPACE_OUTBOX_MAX_ATTEMPTS=8
WORKSPACE_OUTBOX_STALE_CLAIM_THRESHOLD_MS=60000

TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

METRICS_AUTH_TOKEN=
