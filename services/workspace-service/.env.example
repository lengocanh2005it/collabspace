# =============================================================================
# Workspace Service — environment template
# Copy to .env, điền non-secret config, sau đó chạy sync script để lấy secrets.
#
# Docker Compose: postgres, rabbitmq, auth-service hostnames
# Local pnpm:     AUTH_SERVICE_GRPC_URL=127.0.0.1:50051
#
# SECRETS — không điền tay, lấy từ Vault:
#   .\infrastructure\vault\scripts\sync-env-from-vault.ps1
# =============================================================================

NODE_ENV=development
PORT=8080

# -- Auth gRPC -----------------------------------------------------------------
AUTH_SERVICE_GRPC_URL=auth-service:50051
AUTH_SERVICE_GRPC_TIMEOUT_MS=3000
AUTH_SERVICE_URL=http://auth-service:3000
AUTH_SERVICE_TIMEOUT_MS=3000
# Cho phép X-User-Id header ở local dev — KHÔNG bật trên production
ALLOW_DEV_IDENTITY_HEADERS=true

# -- Service-to-service HTTP (Service JWT) ------------------------------------
# Khớp trên user / workspace / task / notification — xem infrastructure/docker/.env.example
# Local: dùng giá trị mặc định bên dưới; prod: sync từ Vault
SERVICE_JWT_SECRET=collabspace-dev-service-jwt-secret-change-me

# -- PostgreSQL ----------------------------------------------------------------
# Password trong URL là VAULT-MANAGED
DATABASE_URL=postgresql://postgres:VAULT_SYNC@postgres:5432/collabspace_workspace?schema=public
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_LOGGING=false
DATABASE_SYNCHRONIZE=true

# -- RabbitMQ ------------------------------------------------------------------
# Credentials trong URL là VAULT-MANAGED
RABBITMQ_URL=amqp://user:VAULT_SYNC@rabbitmq:5672/collabspace

# -- Outbox --------------------------------------------------------------------
WORKSPACE_OUTBOX_ENABLED=true
WORKSPACE_OUTBOX_POLL_INTERVAL_MS=2000
WORKSPACE_OUTBOX_BATCH_SIZE=25
WORKSPACE_OUTBOX_MAX_ATTEMPTS=8
WORKSPACE_OUTBOX_STALE_CLAIM_THRESHOLD_MS=60000

# -- Tracing -------------------------------------------------------------------
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
JAEGER_AGENT_HOST=jaeger
OTEL_LOG_LEVEL=

# -- Metrics -------------------------------------------------------------------
METRICS_AUTH_TOKEN=                  # VAULT-MANAGED (để trống = không yêu cầu auth ở local)
