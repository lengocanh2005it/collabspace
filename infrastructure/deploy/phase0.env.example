# Biến Phase 0 — copy thành phase0.env và điền giá trị thật.
# phase0.env được gitignore — KHÔNG commit.
#
#   cp infrastructure/deploy/phase0.env.example infrastructure/deploy/phase0.env
#   nano infrastructure/deploy/phase0.env
#   ./infrastructure/deploy/prepare-prod-values.sh

# --- Droplet & domain ---
DROPLET_HOST=
DROPLET_SSH_USER=root
# API public: domain HOẶC IP Droplet (không có http://)
# Ví dụ IP-only: PROD_DOMAIN=165.xxx.xxx.xxx
PROD_DOMAIN=api.example.com

# --- GHCR (image từ GitHub Actions) ---
GHCR_OWNER=lengocanh2005it
# Tag image: commit SHA main mới nhất hoặc git tag
IMAGE_TAG=latest
# PAT GitHub (repo private + pull image GHCR) — có thể dùng MỘT token cho cả hai:
#   Classic PAT: tick repo + read:packages
# GHCR_USERNAME=lengocanh2005it
# GHCR_TOKEN=ghp_...
# GITHUB_TOKEN=   # tùy chọn; nếu trống sẽ dùng GHCR_TOKEN để git clone/pull trên Droplet

# --- Secret production (phải khớp Vault secret/collabspace/prod) ---
# Sinh mạnh: openssl rand -base64 32
# SERVICE_JWT_SECRET — dùng chung cho user/workspace/task/notification (S2S HTTP)
JWT_SECRET=
SERVICE_JWT_SECRET=
POSTGRES_PASSWORD=
MONGO_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_PASSWORD=
RABBITMQ_USERNAME=collabspace
METRICS_AUTH_TOKEN=
# Cookie Erlang RabbitMQ — openssl rand -hex 16
RABBITMQ_ERLANG_COOKIE=

# --- Azure Blob Storage (task attachments; user-service dùng cùng connection string) ---
# Bắt buộc bọc trong dấu ngoặc kép — connection string chứa dấu ';'
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=task-attachments
AZURE_STORAGE_MAX_FILE_SIZE=5242880
