# Biến Phase 0 — copy thành phase0.env và điền giá trị thật.
# phase0.env được gitignore — KHÔNG commit.
#
#   cp infrastructure/deploy/phase0.env.example infrastructure/deploy/phase0.env
#   nano infrastructure/deploy/phase0.env
#   ./infrastructure/deploy/prepare-prod-values.sh

# --- Droplet & domain ---
DROPLET_HOST=
DROPLET_SSH_USER=root
# API public hostname (không có http://). Khi bật TLS Traefik, dùng domain — KHÔNG dùng IP
# (IP → smoke/E2E fallback localhost HTTP → 301). Ví dụ: collabspace.ngocanh2005it.site
PROD_DOMAIN=api.example.com

# --- GHCR (image từ GitHub Actions) ---
GHCR_OWNER=lengocanh2005it
# Tag image trong phase0.env — prepare-prod-values.sh tự refresh từ origin/main (hoặc HEAD)
# khi chạy helm-rollout / prepare-prod-values (tránh pin SHA cũ gây rollback).
# CI vẫn override bằng IMAGE_TAG export trước helm-rollout.
IMAGE_TAG=latest
# PAT GitHub (repo private + pull image GHCR) — có thể dùng MỘT token cho cả hai:
#   Classic PAT: tick repo + read:packages
# GHCR_USERNAME=lengocanh2005it
# GHCR_TOKEN=ghp_...
# GITHUB_TOKEN=   # tùy chọn; nếu trống sẽ dùng GHCR_TOKEN để git clone/pull trên Droplet

# --- Secret production (phải khớp Vault secret/collabspace/prod) ---
# Sinh mạnh: openssl rand -base64 32
# SERVICE_JWT_SECRET — dùng chung cho user/workspace/task/notification (S2S HTTP)
JWT_SECRET=
SERVICE_JWT_SECRET=
POSTGRES_PASSWORD=
MONGO_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_PASSWORD=
RABBITMQ_USERNAME=collabspace
METRICS_AUTH_TOKEN=
# Cookie Erlang RabbitMQ — openssl rand -hex 16
RABBITMQ_ERLANG_COOKIE=

# --- Brevo transactional email (auth-service — bắt buộc cho prod seed / auth-service) ---
# API key: Brevo → SMTP & API → API keys (xkeysib-...)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME="CollabSpace Platform"

# --- Azure Blob Storage (task attachments; user-service dùng cùng connection string) ---
# Bắt buộc bọc trong dấu ngoặc kép — connection string chứa dấu ';'
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=task-attachments
AZURE_STORAGE_MAX_FILE_SIZE=5242880

# --- DigitalOcean Spaces (backup CronJob — postgres + mongo hàng đêm) ---
# Tạo key: DO Console → API → Spaces Keys → Generate New Key
# Đây là Spaces Access Key — khác hoàn toàn với DO API Token.
# Key này cấp quyền đọc/ghi bucket; inject vào K8s Secret "backup-spaces-secret" qua ESO.
DO_SPACES_KEY=
DO_SPACES_SECRET=

# --- Slack alerts (Alertmanager Incoming Webhook) ---
# Slack App → Incoming Webhooks → Webhook URL
# Inject vào K8s Secret "alertmanager-slack-secret" qua ESO (Vault key slack_alert_webhook_url).
SLACK_ALERT_WEBHOOK_URL=

# --- Kafka / Debezium migration (Phase 3–4) ----------------------------------
# Không phải secret — đặt trong values-prod.yaml → services.*.extraEnv (không seed Vault).
# prepare-prod-values.sh không đọc các biến dưới; tham chiếu khi rollout migration trên prod.
#
# workspace-service:
#   WORKSPACE_OUTBOX_PUBLISH_MODE=debezium
# user-service:
#   USER_OUTBOX_PUBLISH_MODE=debezium
#   RABBITMQ_ENABLED=true          # consumer auth events (vẫn cần)
# task-service + notification-service:
#   KAFKA_CONSUMERS_ENABLED=true
#   KAFKA_BROKERS=<kafka-bootstrap>:9092
#   RABBITMQ_ENABLED=false         # sau dual-run ổn định
#
# Topic defaults (không cần override): collabspace.workspace.*, collabspace.user.*
# Connectors: scripts/register-workspace-outbox-connector.ps1, register-user-outbox-connector.ps1, register-task-outbox-connector.ps1
