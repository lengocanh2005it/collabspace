# Copy to /opt/collabspace/infrastructure/deploy/droplet.env on the Droplet.
# Do not commit the real droplet.env file.

# GHCR namespace, normally ghcr.io/<github-owner-or-org>
COLLABSPACE_IMAGE_REGISTRY=ghcr.io/your-github-owner

# Image tag to deploy. GitHub Actions sets this to the commit SHA.
COLLABSPACE_IMAGE_TAG=latest

# Optional. Required when GHCR packages are private.
GHCR_USERNAME=
GHCR_TOKEN=

# HashiCorp Vault as secret source.
# The deploy script syncs Vault values into service .env files before Compose starts.
USE_VAULT_SYNC=true
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=replace-with-vault-read-token
VAULT_KV_PATH=collabspace/prod

# Compose project name used on the Droplet.
COMPOSE_PROJECT_NAME=collabspace

# Run TypeORM migrations before starting app services.
RUN_MIGRATIONS=true

# Optional demo data load. Leave false for production data.
RUN_SEED=false
