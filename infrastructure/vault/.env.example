# Vault local dev (docker-compose.vault.yml)
# Copy to infrastructure/vault/.env if you override defaults.

VAULT_ADDR=http://127.0.0.1:8200
VAULT_DEV_ROOT_TOKEN=collabspace-dev-root

# KV v2 path prefix (do not change unless you update scripts + ESO manifests)
VAULT_KV_MOUNT=secret
VAULT_KV_PATH=collabspace/dev

# Default dev secret values (seed script) — align with infrastructure/docker/.env.example
COLLABSPACE_JWT_SECRET=collabspace-dev-jwt-secret-change-me
COLLABSPACE_INTERNAL_SERVICE_TOKEN=collabspace-dev-internal-token-change-me
COLLABSPACE_POSTGRES_PASSWORD=postgres
COLLABSPACE_MONGO_USERNAME=admin
COLLABSPACE_MONGO_PASSWORD=password
COLLABSPACE_REDIS_PASSWORD=collabspace123
COLLABSPACE_RABBITMQ_USERNAME=guest
COLLABSPACE_RABBITMQ_PASSWORD=guest
COLLABSPACE_METRICS_AUTH_TOKEN=
