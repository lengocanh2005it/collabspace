      "title": "Total Tasks",
      "type": "stat",
      "targets": [
        {
          "expr": "analytics_snapshot_tasks_total{job=\"analytics-service\"}",
          "legendFormat": "Tasks",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
