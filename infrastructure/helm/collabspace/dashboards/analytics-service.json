      "title": "Total Projects",
      "type": "stat",
      "targets": [
        {
          "expr": "analytics_snapshot_projects_total{job=\"analytics-service\"}",
          "legendFormat": "Projects",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
