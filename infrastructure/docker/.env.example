# =============================================================================
# Docker Compose stack — optional root overrides
# =============================================================================
# Usage from infrastructure/docker:
#   docker compose -f docker-compose.yml -f docker-compose.db.yml -f docker-compose.override.yml up -d
#
# override.yml includes exporters + monitoring (Grafana :3005, Prometheus :9090).
#
# Required before first `up`:
#   1. cp services/*/.env.example → services/*/.env (non-secret config + VAULT_SYNC placeholders)
#   2. Vault dev — điền secrets vào .env (khuyến nghị):
#        docker compose -f docker-compose.vault.yml up -d
#        ../vault/scripts/seed-dev-secrets.ps1
#        ../vault/scripts/sync-env-from-vault.ps1
#      Hoặc điền tay dev credentials (xem vault/.env.example) thay bước Vault.
#   3. infrastructure/rabbitmq/.env (nếu dùng RabbitMQ)
#
# Service .env paths:
#   services/auth-service/.env
#   services/user-service/.env
#   services/workspace-service/.env
#   services/task-service/.env
#   services/notification-service/.env
#
# Optional overlays (add with -f):
#   docker-compose.kafka.yml     — Kafka (KRaft) + Debezium Connect (Phase 0–1 migration)
#   docker-compose.traefik.yml   — API gateway on http://localhost/api/v1/...
#   docker-compose.logging.yml   — ELK / Kibana :5601
#   docker-compose.tracing.yml   — Jaeger + TRACING_ENABLED on services
#
# =============================================================================
# HashiCorp Vault — local dev (khuyến nghị trước khi `docker compose up`)
# =============================================================================
# Apps đọc services/*/.env — Vault là nguồn secret; sync script ghi vào .env.
#   docker compose -f docker-compose.vault.yml up -d
#   ../vault/scripts/seed-dev-secrets.ps1
#   ../vault/scripts/sync-env-from-vault.ps1
# Chi tiết: infrastructure/vault/README.md
#
# =============================================================================
# Shared dev secrets (reference — Vault seed dùng cùng giá trị mặc định)
# =============================================================================
#
# JWT_SECRET (auth-service, notification-service):
#   collabspace-dev-jwt-secret-change-me
#
# SERVICE_JWT_SECRET (user, workspace, task, notification):
#   collabspace-dev-service-jwt-secret-change-me
#   — S2S HTTP auth (iss/aud/scope); must match across all four services
#
# ALLOW_DEV_IDENTITY_HEADERS (workspace, task, notification .env for local Docker):
#   true  — curl direct ports with X-User-Id when testing without JWT
#   false — production / gateway-only identity
#
# CORS_ORIGINS (all services — comma-separated list of allowed origins):
#   http://localhost:5173,http://localhost:3000  — local dev default
#   https://app.collabspace.dev                 — production
#
# SWAGGER_ENABLED (all services):
#   true  — enable Swagger UI (default in dev)
#   false — disable in production
#
# COMMAND_TIMEOUT_MS (notification-service RabbitMQ handlers — prod dual-run only):
#   10000 — default 10 s
#
# Kafka migration (infrastructure/kafka/README.md):
#   docker compose ... -f docker-compose.kafka.yml up -d kafka debezium-connect
#   scripts/register-workspace-outbox-connector.ps1
#   scripts/register-user-outbox-connector.ps1
#   scripts/register-task-outbox-connector.ps1
#   services/*/\.env: KAFKA_CONSUMERS_ENABLED=true, RABBITMQ_ENABLED=false (consumers)
#   workspace-service: WORKSPACE_OUTBOX_PUBLISH_MODE=debezium
#   user-service: USER_OUTBOX_PUBLISH_MODE=debezium
#   task-service: TASK_OUTBOX_PUBLISH_MODE=debezium
#
# Auth gRPC (workspace, task, notification, user HTTP routes):
#   AUTH_SERVICE_GRPC_URL=auth-service:50051
#
# =============================================================================

COMPOSE_PROJECT_NAME=collabspace

# Canonical local dev secrets (mirrored in services/*/.env and infrastructure/vault/.env.example)
JWT_SECRET=collabspace-dev-jwt-secret-change-me
SERVICE_JWT_SECRET=collabspace-dev-service-jwt-secret-change-me
POSTGRES_PASSWORD=postgres
MONGO_USERNAME=admin
MONGO_PASSWORD=password
REDIS_PASSWORD=collabspace123
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Host scripts only (connector registration, smoke tests) — see infrastructure/kafka/.env.example
KAFKA_BROKERS_HOST=localhost:29092
DEBEZIUM_CONNECT_URL_HOST=http://localhost:8083

# Brevo (auth-service — copy vào services/auth-service/.env)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=CollabSpace Platform
