# Host-only env for Kafka / Debezium scripts (repo root or infrastructure/kafka/).
# Copy to .env before running scripts under scripts/.
#
# In-docker apps set KAFKA_BROKERS=kafka:9092 in services/*/.env (not here).

DEBEZIUM_CONNECT_URL_HOST=http://localhost:8083
KAFKA_BROKERS_HOST=localhost:29092

# Phase 7 — DLQ replay / smoke (host scripts)
KAFKA_DLQ_TOPIC=collabspace.dlq.events
KAFKA_EXPORTER_URL=http://localhost:9308/metrics
SCHEMA_REGISTRY_URL=http://localhost:8081/subjects

# Connector registration (stack: docker compose ... -f docker-compose.kafka.yml up -d):
#   scripts/register-workspace-outbox-connector.ps1
#   scripts/register-user-outbox-connector.ps1
#   scripts/register-task-outbox-connector.ps1
#
# E2E smoke:
#   scripts/kafka-phase3-e2e.ps1
#   scripts/kafka-phase4-e2e.ps1
#   scripts/kafka-phase5-e2e.ps1
#   scripts/kafka-phase7-smoke.ps1
