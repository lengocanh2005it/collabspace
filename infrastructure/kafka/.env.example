# Optional env for Kafka / Debezium scripts run from the host (repo root).
# Copy to .env and source before running scripts under scripts/ and infrastructure/kafka/.
#
# In-container services use services/notification-service/.env (KAFKA_BROKERS=kafka:9092).

DEBEZIUM_CONNECT_URL_HOST=http://localhost:8083
KAFKA_BROKERS_HOST=localhost:29092

# Connector registration (defaults match infrastructure/kafka/connectors/)
# DEBEZIUM_CONNECT_URL_HOST used by scripts/register-workspace-outbox-connector.ps1
