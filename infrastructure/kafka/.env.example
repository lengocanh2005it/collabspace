# Host-only env for Kafka / Debezium scripts (repo root or infrastructure/kafka/).
# Copy to .env before running scripts under scripts/.
#
# In-docker apps set KAFKA_BROKERS=kafka:9092 in services/*/\.env (not here).

DEBEZIUM_CONNECT_URL_HOST=http://localhost:8083
KAFKA_BROKERS_HOST=localhost:29092

# Connector registration:
#   scripts/register-workspace-outbox-connector.ps1
#   scripts/register-user-outbox-connector.ps1
