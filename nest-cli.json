{
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/task-service/src",
  "compilerOptions": {
    "webpack": true, 
    "tsConfigPath": "services/task-service/tsconfig.json"
  },
  "projects": {
    "task-service": {
      "type": "application",
      "root": "services/task-service",
      "entryFile": "main",
      "sourceRoot": "services/task-service/src",
      "compilerOptions": {
        "tsConfigPath": "services/task-service/tsconfig.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}