#!/bin/sh
# .githooks/pre-commit
# Block the accidental commitment of real .env files containing secrets.

# Check if any staged files are named exactly .env (or ending in /.env)
if git diff --cached --name-only | grep -E '(^|/)\.env$'; then
  echo "==================================================================="
  echo "❌ DEVSECOPS SECURITY ERROR: You are trying to commit a .env file!"
  echo "==================================================================="
  echo "Committing real environment variables to Git is a severe security risk."
  echo "Please unstage the file and commit again:"
  echo ""
  echo "  git restore --staged <path-to/.env>"
  echo ""
  echo "If you meant to update the template, use .env.example instead."
  exit 1
fi

# Biome format/lint on staged files (services + packages)
if command -v pnpm >/dev/null 2>&1; then
  pnpm exec biome check --staged --assist-enabled=false --files-ignore-unknown=true --no-errors-on-unmatched
  if [ $? -ne 0 ]; then
    echo ""
    echo "Biome check failed on staged files."
    echo "Fix with: pnpm run biome:fix   (or format only: pnpm run format)"
    exit 1
  fi
fi

exit 0
