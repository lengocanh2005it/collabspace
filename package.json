{
  "name": "collabspace",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm run lint:ci",
    "lint:deps": "pnpm --filter @collabspace/shared build && pnpm --filter @collabspace/nest-auth build",
    "lint:ci": "pnpm run lint:deps && pnpm run format:check && pnpm run biome:check && pnpm run lint:types",
    "lint:types": "pnpm -r run lint",
    "format": "biome format --write services packages",
    "format:check": "biome format services packages",
    "biome:check": "biome check --assist-enabled=false services packages",
    "biome:fix": "biome check --write --assist-enabled=false services packages",
    "seed": "sh ./scripts/seed.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
